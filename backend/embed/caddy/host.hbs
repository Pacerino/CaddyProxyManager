{{host.domains}} {
{{#if BasicAuth}}
	basic_auth {
{{#each BasicAuth}}
		{{User}} {{Hash}}
{{/each}}
	}
{{/if}}
{{#if host.upstreams}}
{{#if host.matcher}}
	reverse_proxy {{host.matcher}}{{#each host.upstreams}} {{backend}}{{/each}}
{{else}}
	reverse_proxy{{#each host.upstreams}} {{backend}}{{/each}}
{{/if}}
{{/if}}
{{#if LogPath}}
	log {
		output file {{LogPath}}
	}
{{/if}}
}
